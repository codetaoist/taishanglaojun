# 码道 (Code Taoist) 环境配置文件
# 复制此文件为 .env 并根据实际情况修改配置

# =============================================================================
# 数据库配置
# =============================================================================
POSTGRES_PASSWORD=codetaoist123
POSTGRES_DB=codetaoist
POSTGRES_USER=codetaoist

# =============================================================================
# 对象存储配置 (MinIO)
# =============================================================================
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# =============================================================================
# 认证服务配置 (Keycloak)
# =============================================================================
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# =============================================================================
# AI 模型配置
# =============================================================================
# OpenAI API 密钥
OPENAI_API_KEY=your-openai-api-key-here

# DeepSeek API 密钥
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# =============================================================================
# 监控配置
# =============================================================================
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123

# =============================================================================
# 应用配置
# =============================================================================
# 环境类型: development, production, test
ENVIRONMENT=development

# 调试模式
DEBUG=true

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API 域名
API_DOMAIN=api.codetaoist.com

# =============================================================================
# 安全配置
# =============================================================================
# JWT 密钥 (生产环境请使用强密钥)
SECRET_KEY=your-super-secret-jwt-key-change-in-production

# 允许的主机列表 (逗号分隔)
ALLOWED_HOSTS=localhost,127.0.0.1,api.codetaoist.com

# =============================================================================
# 性能配置
# =============================================================================
# 数据库连接池大小
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# API 限流配置
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# 文件上传限制 (字节)
MAX_FILE_SIZE=10485760

# =============================================================================
# 开发配置
# =============================================================================
# 是否启用 API 文档
ENABLE_DOCS=true

# 是否启用监控指标
ENABLE_METRICS=true

# 是否启用详细日志
VERBOSE_LOGGING=true