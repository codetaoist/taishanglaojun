# E2E Test Environment Configuration

# Application URLs
BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:8080

# Test Environment
NODE_ENV=test
TEST_RUN_ID=local-test-run

# Browser Configuration
HEADLESS=true
SLOW_MO=0
TIMEOUT=30000

# Test Data
TEST_ADMIN_EMAIL=admin@test.com
TEST_ADMIN_PASSWORD=test123456
TEST_USER_EMAIL=user@test.com
TEST_USER_PASSWORD=test123456

# Regional Testing
DEFAULT_REGION=us-east-1
TEST_REGIONS=us-east-1,eu-central-1,ap-east-1

# Compliance Testing
GDPR_ENABLED=true
CCPA_ENABLED=true
PIPL_ENABLED=true

# Performance Testing
PERFORMANCE_BUDGET_FCP=1800
PERFORMANCE_BUDGET_LCP=2500
PERFORMANCE_BUDGET_LOAD_TIME=3000

# Security Testing
SECURITY_HEADERS_ENABLED=true
CSRF_PROTECTION_ENABLED=true
XSS_PROTECTION_ENABLED=true

# Database Configuration (for test data setup)
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=taishanglaojun_test
TEST_DB_USER=test_user
TEST_DB_PASSWORD=test_password

# Redis Configuration (for session testing)
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
TEST_REDIS_PASSWORD=

# Email Testing (for verification flows)
TEST_EMAIL_PROVIDER=mock
TEST_EMAIL_API_KEY=test_key

# Payment Testing
TEST_PAYMENT_PROVIDER=stripe_test
TEST_STRIPE_PUBLISHABLE_KEY=pk_test_...
TEST_STRIPE_SECRET_KEY=sk_test_...

# AI Service Testing
TEST_AI_PROVIDER=mock
TEST_AI_API_KEY=test_ai_key

# File Upload Testing
TEST_UPLOAD_MAX_SIZE=10485760
TEST_UPLOAD_ALLOWED_TYPES=jpg,png,pdf,doc,docx

# Monitoring and Logging
TEST_LOG_LEVEL=info
TEST_METRICS_ENABLED=true
TEST_TRACING_ENABLED=false

# Parallel Testing
TEST_WORKERS=4
TEST_RETRIES=2

# Report Configuration
ALLURE_RESULTS_DIR=allure-results
PLAYWRIGHT_REPORT_DIR=playwright-report
TEST_RESULTS_DIR=test-results

# CI/CD Configuration
CI=false
GITHUB_ACTIONS=false
JENKINS=false

# Debug Configuration
DEBUG_MODE=false
SCREENSHOT_ON_FAILURE=true
VIDEO_ON_FAILURE=true
TRACE_ON_RETRY=true

# Localization Testing
DEFAULT_LOCALE=zh-CN
TEST_LOCALES=zh-CN,en-US,de-DE,ja-JP,ko-KR
TIMEZONE_TESTING=true
CURRENCY_TESTING=true

# Mobile Testing
MOBILE_TESTING_ENABLED=true
TABLET_TESTING_ENABLED=true
DESKTOP_TESTING_ENABLED=true

# Network Simulation
NETWORK_SIMULATION=false
SLOW_3G_ENABLED=false
FAST_3G_ENABLED=false
OFFLINE_TESTING=false

# Accessibility Testing
A11Y_TESTING_ENABLED=true
WCAG_LEVEL=AA
COLOR_CONTRAST_TESTING=true

# Load Testing
LOAD_TESTING_ENABLED=false
CONCURRENT_USERS=10
TEST_DURATION=300

# Feature Flags
FEATURE_GLOBAL_DEPLOYMENT=true
FEATURE_MULTI_LANGUAGE=true
FEATURE_COMPLIANCE_SUITE=true
FEATURE_AI_INTEGRATION=true
FEATURE_REAL_TIME_CHAT=true

# Third-party Integrations
GOOGLE_ANALYTICS_TESTING=false
MIXPANEL_TESTING=false
SENTRY_TESTING=false

# Backup and Recovery Testing
BACKUP_TESTING_ENABLED=false
DISASTER_RECOVERY_TESTING=false

# Custom Test Configuration
CUSTOM_TEST_SUITE=global-features
SKIP_SLOW_TESTS=false
SKIP_FLAKY_TESTS=false
PARALLEL_EXECUTION=true