{
  "name": "taishanglaojun-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for Taishang Laojun AI Platform global features",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:global": "playwright test --grep @global",
    "test:localization": "playwright test --grep @localization",
    "test:compliance": "playwright test --grep @compliance",
    "test:performance": "playwright test --grep @performance",
    "test:security": "playwright test --grep @security",
    "test:mobile": "playwright test --project=mobile",
    "test:desktop": "playwright test --project=desktop",
    "test:cross-browser": "playwright test --project=chromium --project=firefox --project=webkit",
    "install-browsers": "playwright install",
    "generate-report": "allure generate allure-results --clean -o allure-report",
    "serve-report": "allure serve allure-results"
  },
  "keywords": [
    "e2e",
    "testing",
    "playwright",
    "globalization",
    "localization",
    "compliance"
  ],
  "author": "Taishang Laojun Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "allure-playwright": "^2.9.0",
    "dotenv": "^16.3.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "faker": "^6.6.6",
    "moment": "^2.29.4",
    "moment-timezone": "^0.5.43"
  }
}